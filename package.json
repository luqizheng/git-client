{
  "name": "req2task-2",
  "version": "1.0.0",
  "description": "Multi-package project with Git Client and Agents",
  "private": true,
  "workspaces": [
    "git-client"
  ],
  "scripts": {
    "agents:list": "node scripts/agents/list.js",
    "agents:info": "node scripts/agents/info.js",
    "agents:skills": "ls -la .agents/skills/",
    "dev:git-client": "npm run dev --workspace=git-client",
    "dev:tauri": "npm run tauri dev --workspace=git-client",
    "dev:all": "npm run dev:git-client",
    "build:git-client": "npm run build --workspace=git-client",
    "test:git-client": "npm run test --workspace=git-client",
    "test:git-client:ui": "npm run test:ui --workspace=git-client",
    "test:git-client:watch": "npm run test:watch --workspace=git-client",
    "test:rust": "cd git-client/src-tauri && cargo test",
    "test:rust:clippy": "cd git-client/src-tauri && cargo clippy",
    "test:all": "npm run test:git-client && npm run test:rust",
    "workflow:plan": "echo 'Use: Skill \"writing-plans\" to create implementation plan'",
    "workflow:execute": "echo 'Use: Skill \"subagent-driven-development\" to execute plan'",
    "workflow:review": "echo 'Use: Skill \"requesting-code-review\" for code review'",
    "skills:refresh": "node scripts/agents/refresh.js",
    "mcp:start": "npx @hypothesi/tauri-mcp-server",
    "tauri:dev:mcp": "powershell -Command \"Start-Process -NoNewWindow npm -ArgumentList 'run','dev:tauri'; Start-Process -NoNewWindow npx -ArgumentList '@hypothesi/tauri-mcp-server'\""
  },
  "keywords": [
    "git-client",
    "agents",
    "multi-agent"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@hypothesi/tauri-mcp-server": "^0.11.2"
  }
}
